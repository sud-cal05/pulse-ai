# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.

# --- LLM provider ---
# Which provider the LLMClient should use. Supported: "openai"
LLM_PROVIDER=openai

# API key for the provider above. Get one from platform.openai.com.
OPENAI_API_KEY=sk-your-key-here

# Pinned model name. Pin an exact snapshot in production so a silent
# vendor-side model update can't change your outputs (see DESIGN.md §9).
# Recommended for PulseAI: gpt-5-nano
LLM_MODEL=gpt-5-nano

# Reasoning effort for reasoning-capable models (low | medium | high).
# Start at "low" — raise only if golden-set accuracy needs it.
# Non-reasoning models (e.g. gpt-4.1-mini) ignore this setting.
LLM_REASONING_EFFORT=low

# Temperature — MUST stay at 0 for determinism (M5B1 / M5S2 in the rubric).
# Non-reasoning models only; reasoning models control determinism via
# reasoning_effort instead and may reject an explicit temperature param.
LLM_TEMPERATURE=0

# Embeddings model, used for theme clustering (DESIGN.md §5.2 / §7)
EMBEDDING_MODEL=text-embedding-3-small

# --- Storage ---
DATABASE_PATH=./pulseai.db
